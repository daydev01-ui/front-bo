        let validateAndRegisterBusinnes = (table, formId) => {
            $(`#${formId}`).validate({
               "rules": {
                   "businessName": {
                       "required": true,
                       "minlength": 2,
                       "maxlength": 50
                   },
                   "abbreviation": {
                       "required": true,
                       "minlength": 4,
                       "maxlength": 10
                   }
               },
               "messages": {
                   "businessName": {
                       "required": "El campo no debe ser vacio.",
                       "minlength": "El campo debe tener al menos {0} caracteres",
                       "maxlength": "El campo debe tener maximo {0} caracteres"
                   },
                   "abbreviation": {
                       "required": "El campo no debe ser vacio.",
                       "minlength": "El campo debe tener al menos {0} caracteres",
                       "maxlength": "El campo debe tener maximo {0} caracteres"
                   }
                },
                "errorClass": "is-invalid",
                "validClass": "is-valid",
                "errorElement": "span",
                "highlight": function (element, errorClass, validClass) {
                    $(element).addClass(errorClass).removeClass(validClass);
                },
                "unhighlight": function (element, errorClass, validClass) {
                    $(element).removeClass(errorClass).addClass(validClass);
                },
                "submitHandler": function (form, e) {
                    showLoader();
                    e.preventDefault();
                    const formData = new FormData(form);
                    const body = Object.fromEntries(formData.entries());
                    $.ajax({
                        "url": '@Url.Action("Register", "Business")',
                        "type": 'POST',
                        "data": JSON.stringify(body),
                        "contentType": 'application/json',
                        success: function (resp) {
                            table.row.add(resp).draw();
                            showTooltips();
                            hideModal('modalRegisterBusiness');
                            resetForm('formRegisterBusiness');
                            countRows(table, 'totalBusinesses');
                            alertSuccess(resp.businessName, `Empresa <strong>#${resp.businessCode}</strong> creada correctamente.`);
                        },
                        error: function (xhr) {
                            if (xhr.responseJSON && xhr.responseJSON.message) {
                                alertError('Agregar empresa', xhr.responseJSON.message);
                            } else {
                                alertError('Agregar empresa', 'Ha ocurrido un error inesperado.');
                            }
                        },
                        complete: function () {
                            hideLoader();
                        }
                    });
                 }
            });
        }

        let validateAndUpdateBusinnes = (table, formId) => {
            $('#tableBusiness').on('click', '.button--edit', function () {
                openUpdateBusinessModal(this);
            });

            $(`#${formId}`).validate({
              "rules": {
                 "businessName": {
                    "required": true,
                    "minlength": 2,
                    "maxlength": 50
                 }
              },
              "messages": {
                 "businessName": {
                    "required": "El campo no debe ser vacio.",
                    "minlength": "El campo debe tener al menos {0} caracteres",
                    "maxlength": "El campo debe tener maximo {0} caracteres"
                 }
              },
              "errorClass": "is-invalid",
              "validClass": "is-valid",
              "errorElement": "span",
              highlight: function (element, errorClass, validClass) {
                 $(element).addClass(errorClass).removeClass(validClass);
              },
              unhighlight: function (element, errorClass, validClass) {
                 $(element).removeClass(errorClass).addClass(validClass);
              },
              submitHandler: function (form, e) {
                 showLoader();
                 e.preventDefault();
                 const formData = new FormData(form);
                 const body = Object.fromEntries(formData.entries());
                 $.ajax({
                    "url": '@Url.Action("Update", "Business")',
                    "type": 'POST',
                    "data": JSON.stringify(body),
                    "contentType": 'application/json',
                    success: function (resp) {
                       var row = table.row(function (idx, data, node) {
                          return data.businessCode == body.businessCode;
                       });
                       if (row.length) {
                          var rowData = row.data();
                          rowData.businessName = resp.businessName;
                          rowData.modificationUser = resp.modificationUser;
                          rowData.modificationDate = resp.modificationDate;
                          row.data(rowData).draw(false);
                       };
                       showTooltips();
                       hideModal('modalUpdateBusiness');
                       resetForm('formUpdateBusiness');
                       alertSuccess(body.businessName, `Empresa <strong>#${resp.businessCode}</strong> actualizada correctamente.`);
                    },
                    error: function (xhr) {
                        if (xhr.responseJSON && xhr.responseJSON.message) {
                            alertError('Actualizar empresa', xhr.responseJSON.message);
                        } else {
                            alertError('Actualizar empresa', 'Ha ocurrido un error inesperado.');
                        }
                    },
                    complete: function () {
                       hideLoader();
                    }
                 });
              }
           });
        }

        let validateAndRegisterAdminBusiness = (table, formId) => {
            $('#tableBusiness').on('click', '.button--admin', function () {
              openRegisterAdminModal(this);
           });

            $(`#${formId}`).validate({
