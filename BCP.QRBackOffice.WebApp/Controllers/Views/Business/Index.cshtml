                        "maxlength": 20,
                        "noSpaces": true
                    },
                    "documentType": {
                        "required": true
                    },
                    "documentNumber": {
                        "required": true,
                        "minlength": 5,
                        "maxlength": 15
                    },
                    "documentExtension": {
                        "required": true
                    },
                    "userPhone": {
                        "rangelength": [8, 8],
                        "digits": true
                    },
                    "credentialsEmail": {
                        "multiEmail": true
                    }
                },
                "messages": {
                    "fullName": {
                        "required": "El campo no debe ser vacio.",
                        "minlength": "El campo debe tener al menos {0} caracteres",
                        "maxlength": "El campo debe tener maximo {0} caracteres"
                    },
                    "userName": {
                        "required": "El campo no debe ser vacio.",
                        "minlength": "El campo debe tener al menos {0} caracteres",
                        "maxlength": "El campo debe tener maximo {0} caracteres",
                        "noSpaces": "El campo no debe contener espacios."
                    },
                    "documentType": {
                        "required": "El campo no debe ser vacio."
                    },
                    "documentNumber": {
                        "required": "El campo no debe ser vacio.",
                        "minlength": "El campo debe tener al menos {0} caracteres",
                        "maxlength": "El campo debe tener maximo {0} caracteres"
                    },
                    "documentExtension": {
                        "required": "El campo no debe ser vacio."
                    },
                    "userPhone": {
                        "rangelength": "El teléfono debe tener exactamente 8 dígitos.",
                        "digits": "Solo se permiten números."
                    },
                    "credentialsEmail": {
                        "multiEmail": "Debe ingresar entre 1 y 3 correos válidos separados por ';'.",
                    }
                },
                "errorClass": "is-invalid",
                "validClass": "is-valid",
                "errorElement": "span",
                "highlight": function (element, errorClass, validClass) {
                    $(element).addClass(errorClass).removeClass(validClass);
                },
                "unhighlight": function (element, errorClass, validClass) {
                    $(element).removeClass(errorClass).addClass(validClass);
                },
                "submitHandler": function (form, e) {
                    showLoader();
                    e.preventDefault();
                    const formData = new FormData(form);
                    const body = Object.fromEntries(formData.entries());
                    $.ajax({
                        "url": '@Url.Action("AddUserAdmin", "Business")',
                        "type": 'POST',
                        "data": JSON.stringify(body),
                        "contentType": 'application/json',
                        success: function (resp) {
                           var row = table.row(function (idx, data, node) {
                                return data.businessCode == body.businessCode;
                            });
                            if (row.length) {
                                var rowData = row.data();
                                console.log(resp);
                                rowData.isUserAdmin = resp.isUserAdmin;
                                rowData.modificationUser = resp.modificationUser;
                                rowData.modificationDate = resp.modificationDate;
                                row.data(rowData).draw(false);
                            };
                            showTooltips();
                            hideModal('modalRegisterAdmin');
                            resetForm('formRegisterAdmin');
                            alertSuccess(resp.businessName, `Empresa <strong>#${resp.businessCode}</strong>, usuario administrador agregado correctamente.`);
                        },
                        error: function (xhr) {
                            if (xhr.responseJSON && xhr.responseJSON.message) {
                                alertError('Agregar ususario administrador', xhr.responseJSON.message);
                            } else {
                                alertError('Agregar ususario administrador', 'Ha ocurrido un error inesperado.');
                            }
                        },
                        complete: function () {
                            hideLoader();
                        }
                    });
                }
            });
        }

        let loadBusiness = (table) => {
           showLoader();
           $.ajax({
              url: '@Url.Action("GetAll", "Business")',
              type: 'POST',
              contentType: 'application/json',
              dataSrc: '',
              success: function (resp) {
                 table.clear();
                 table.rows.add(resp).draw();
                 countRows(table, 'totalBusinesses');
                 showTooltips();
              },
              error: function (xhr, status, error) {
                  if (xhr.responseJSON && xhr.responseJSON.message) {
                      alertError('Obtener empresas', xhr.responseJSON.message);
                  } else {
                      alertError('Obtener empresas', 'Ha ocurrido un error inesperado.');
                  }
              },
              complete: function () {
                 hideLoader();
              }
           });
        }

        let openUpdateBusinessModal = (button) => {
           const row = $(button).closest('tr');
           const businessCode = row.find('td').eq(0).text().trim();
           const businessName = row.find('td strong').text().trim();
           $('#formUpdateBusinessCode').val(businessCode);
           $('#formUpdateBusinessName').val(businessName);
           showModal('modalUpdateBusiness');
        }

        let openRegisterAdminModal = (button) => {
           const row = $(button).closest('tr');
           const businessCode = row.find('td').eq(0).text().trim();
           const businessName = row.find('td strong').text().trim();
           const isUserAdmin = row.find('td').eq(3).text().trim();
           if(isUserAdmin == 'Si')
           {
               alertError('Agregar usuario administrador', 'La empresa ya tiene un usuario administrador registrado.');
               hideModal('modalRegisterAdmin');
               return;
           }
           $('#formRegisterAdminBusinessCode').val(businessCode);
           $('#formRegisterAdminBusinessName').val(businessName);
           showModal('modalRegisterAdmin');
        }

        let showModal = (modalId) => $(`#${modalId}`).modal('show');
        let hideModal = (modalId) => $(`#${modalId}`).modal('hide');
        let resetForm = (formId) => {
           $(`#${formId}`)[0].reset();
           $(`#${formId}`).find('.is-valid, .is-invalid').removeClass('is-valid is-invalid');
        }
        let countRows = (table, containerId) => $(`#${containerId}`).html(table.data().count());
        let showTooltips = () => $('[data-bs-toggle="popover"]').each(function () { new bootstrap.Popover(this); });
    </script>
}