@{
    ViewData["Title"] = "Reportes QR";
}

<div class="container mt-4">

    <div class="text-center mb-4">
        <h3><strong>Reportes QR</strong></h3>
    </div>

    @if (TempData["ErrorReporte"] != null)
    {
        <div class="row justify-content-center mb-3">
            <div class="col-lg-4 col-md-6 col-sm-12">
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <strong>Error:</strong> @TempData["ErrorReporte"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        </div>
    }

    <div class="row justify-content-center">
        <div class="col-lg-4 col-md-6 col-sm-12">

            <div class="card shadow p-3">
                <div class="card-body">

                    <h5 class="text-center mb-3">Filtros Avanzados</h5>

                    <!-- EMPRESA -->
                    <div class="mb-2">
                        <label>Empresa</label>
                        <input type="text" class="form-control" id="empresaSearch"
                               placeholder="Buscar empresa..." autocomplete="off" />
                        <select class="form-control mt-1" id="empresa" size="5"
                                style="display:none; overflow-y:auto;">
                            <option value="">Todas</option>
                        </select>
                        <input type="hidden" id="empresaCodigo" value="" />
                        <small id="empresaSeleccionada" class="text-muted" style="display:none;"></small>
                    </div>

                    <!-- ESTADO -->
                    <div class="mb-2">
                        <label>Estado</label>
                        <select class="form-control" id="estado">
                            <option value="">Todos</option>
                            <option value="PROCESADOS">Procesados</option>
                            <option value="EN_COLA">En Cola</option>
                        </select>
                    </div>

                    <!-- MES -->
                    <div class="mb-2">
                        <label>Mes</label>
                        <input type="month" class="form-control" id="month" />
                    </div>

                    <!-- FECHA INICIO -->
                    <div class="mb-2">
                        <label>Fecha Inicio</label>
                        <input type="date" class="form-control" id="fInicio" />
                    </div>

                    <!-- FECHA FIN -->
                    <div class="mb-2">
                        <label>Fecha Fin</label>
                        <input type="date" class="form-control" id="fFin" />
                    </div>

                    <!-- MENSAJE VALIDACIÓN FECHAS -->
                    <div id="warningMessage" class="alert alert-warning mt-2" style="display:none;">
                        La fecha inicial no puede ser mayor que la fecha final.
                    </div>

                    <!-- BOTONES -->
                    <div class="d-grid gap-2 mt-3">
                        <button class="btn btn-success" id="btnExcel">
                            <span id="btnExcelText">Exportar Excel</span>
                            <span id="btnExcelSpinner" class="spinner-border spinner-border-sm ms-2" style="display:none;" role="status"></span>
                        </button>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const monthInput = document.getElementById("month");
            const startInput = document.getElementById("fInicio");
            const endInput   = document.getElementById("fFin");
            const msg        = document.getElementById("warningMessage");
            const btnExcel   = document.getElementById("btnExcel");
            const empresaSearch     = document.getElementById("empresaSearch");
            const empresaSelect     = document.getElementById("empresa");
            const empresaSelLabel   = document.getElementById("empresaSeleccionada");

            // -- Inicializar mes actual ------------------------------------------
            const hoy = new Date();
            monthInput.value = hoy.toISOString().slice(0, 7);

            function setFechasMes() {
                const selectedMonth = monthInput.value;
                if (!selectedMonth) return;
                const [year, month] = selectedMonth.split('-').map(Number);
                const firstDay = new Date(year, month - 1, 1);
                const lastDay  = new Date(year, month, 0);
                startInput.value = firstDay.toISOString().split('T')[0];
                endInput.value   = lastDay.toISOString().split('T')[0];
                startInput.min   = startInput.value;
                startInput.max   = endInput.value;
                endInput.min     = startInput.value;
                endInput.max     = endInput.value;
            }

            function validarFechas() {
                if (!startInput.value || !endInput.value) return;
                if (new Date(startInput.value) > new Date(endInput.value)) {
                    msg.style.display = "block";
                    btnExcel.disabled = true;
                } else {
                    msg.style.display = "none";
                    btnExcel.disabled = false;
                }
            }

            function formatearFecha(fecha) {
                const d   = new Date(fecha);
                const dia = String(d.getDate()).padStart(2, '0');
                const mes = String(d.getMonth() + 1).padStart(2, '0');
                return `${dia}/${mes}/${d.getFullYear()}`;
            }

            startInput.addEventListener("change", validarFechas);
            endInput.addEventListener("change", validarFechas);
            monthInput.addEventListener("change", setFechasMes);
            setFechasMes();

            // -- Cargar empresas via AJAX ----------------------------------------
            let todasEmpresas = [];

            $.ajax({
                url: '@Url.Action("GetAllEmpresas", "Report")',
                type: 'POST',
                headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                success: function (data) {
                    todasEmpresas = data;
                    poblarSelect(data);
                },
                error: function (xhr) {
                    console.error('Error cargando empresas:', xhr.status, xhr.responseText);
                }
            });

            function poblarSelect(lista) {
                // Limpiar opciones previas excepto "Todas"
                while (empresaSelect.options.length > 1) {
                    empresaSelect.remove(1);
                }
                lista.forEach(function (e) {
                    const opt = document.createElement('option');
                    opt.value       = e.id;
                    opt.textContent = e.text;
                    empresaSelect.appendChild(opt);
                });
            }

            // Mostrar / filtrar el select al escribir en el buscador
            empresaSearch.addEventListener("input", function () {
                const query = empresaSearch.value.trim().toLowerCase();
                if (query.length === 0) {
                    empresaSelect.style.display = "none";
                    return;
                }
                const filtradas = todasEmpresas.filter(e =>
                    (e.text || '').toLowerCase().includes(query)
                );
                poblarSelect(filtradas);
                empresaSelect.style.display = filtradas.length > 0 ? "block" : "none";
            });

            // Al seleccionar una opción del dropdown
            empresaSelect.addEventListener("change", function () {
                const opt = empresaSelect.options[empresaSelect.selectedIndex];
                empresaSearch.value         = opt.textContent;
                empresaSelLabel.textContent = opt.value ? `Código: ${opt.value}` : '';
                empresaSelLabel.style.display = opt.value ? "inline" : "none";
                empresaSelect.style.display = "none";
            });

            // Cerrar el select al hacer clic fuera
            document.addEventListener("click", function (e) {
                if (e.target !== empresaSearch && e.target !== empresaSelect) {
                    empresaSelect.style.display = "none";
                }
            });

            // -- Exportar Excel --------------------------------------------------
            btnExcel.addEventListener("click", function () {
                const empresa = empresaSelect.value;
                const estado  = document.getElementById("estado").value;
                const fInicio = formatearFecha(startInput.value);
                const fFin    = formatearFecha(endInput.value);

                document.getElementById("btnExcelText").textContent = "Generando...";
                document.getElementById("btnExcelSpinner").style.display = "inline-block";
                btnExcel.disabled = true;

                // Restaurar botón tras descarga (timeout estimado)
                setTimeout(function () {
                    document.getElementById("btnExcelText").textContent = "Exportar Excel";
                    document.getElementById("btnExcelSpinner").style.display = "none";
                    btnExcel.disabled = false;
                }, 5000);

                window.location.href = `/Report/ExportarExcel?empresa=${encodeURIComponent(empresa)}&estado=${encodeURIComponent(estado)}&fInicio=${encodeURIComponent(fInicio)}&fFin=${encodeURIComponent(fFin)}`;
            });
        });
    </script>
}
