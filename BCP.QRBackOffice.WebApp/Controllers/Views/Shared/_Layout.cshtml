    <section class="modal2">
        <div class="loader">
            <div class="loader__container">
                <div class="loader__img">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M20.8582 14.427C18.4013 18.351 11.699 22.8238 9.79985 23.4946C6.10638 25.04 3.60596 22.1739 3.39248 21.8733C2.70343 20.9859 2.53606 20.7984 2.20259 20.151C2.13754 20.2584 9.2927 16.9299 11.8563 12.6238C14.6327 8.92531 14.8746 1.67036 11.8424 0.306152C12.7594 0.767837 14.9201 2.00826 16.8697 3.74573C18.815 5.39478 20.4963 7.55731 20.4603 7.52952C20.6655 7.80805 23.1022 10.8409 20.8582 14.427Z" fill="#FF7800"></path>
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M13.0396 10.492C14.6192 6.64315 14.3627 1.43957 11.8427 0.305884C9.53559 -0.776643 6.91264 2.30546 6.79011 2.46525C6.79011 2.46525 5.92422 3.52188 5.26611 5.00104C5.71769 5.24736 6.58232 5.6762 6.58232 5.6762C8.35706 6.52757 10.7608 8.02125 13.0396 10.492Z" fill="#fff"></path>
                    </svg>
                </div>
                <div class="spinner-border loader__spiner" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
            <p class="text-center loader__text">
                Espere un momento porfavor...
            </p>
        </div>
    </section>

    

    @* ==================== Bootstrap v5.3.3 JS ==================== *@
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @* ==================== CDN JQuery v3.7.1 JS ==================== *@
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
    @* ============ jquery Validate v1.19.5 JS ============ *@
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    @* ==================== CDN DataTables v2.2.1 ==================== *@
    <script src="https://cdn.datatables.net/2.2.1/js/dataTables.js"></script>
    @* ==================== CDN DataTables Bootstrap v2.2.1 ====================  *@
    <script src="https://cdn.datatables.net/2.2.1/js/dataTables.bootstrap5.js"></script>
    @* ==================== CDN DataTables Responsive v3.0.3 ====================  *@
    <script src="https://cdn.datatables.net/responsive/3.0.3/js/dataTables.responsive.js"></script>
    <script src="https://cdn.datatables.net/responsive/3.0.3/js/responsive.bootstrap5.js"></script>

    <script>
        $(document).ready(function () {
            const themeToggle = document.getElementById("theme-toggle");
            const darkIcon = document.getElementById("dark-icon");
            const lightIcon = document.getElementById("light-icon");
            const htmlElement = document.documentElement;

            const currentTheme = localStorage.getItem("theme") || "light";
            htmlElement.setAttribute("data-bs-theme", currentTheme);

            if (currentTheme == "dark") {
                darkIcon.style.display = "none";
                lightIcon.style.display = "block";
            } else {
                darkIcon.style.display = "block";
                lightIcon.style.display = "none";
            }

            themeToggle.addEventListener("click", () => {
                if (htmlElement.getAttribute("data-bs-theme") === "light") {
                    htmlElement.setAttribute("data-bs-theme", "dark");
                    localStorage.setItem("theme", "dark");
                    darkIcon.style.display = "none";
                    lightIcon.style.display = "block";
                } else {
                    htmlElement.setAttribute("data-bs-theme", "light");
                    localStorage.setItem("theme", "light");
                    darkIcon.style.display = "block";
                    lightIcon.style.display = "none";
                }
            });
            
            $('[data-bs-toggle="popoverHeader"]').each(function () {
                new bootstrap.Popover(this);
            });

            $('#btnLogOut').on('click', function(e) {
                showLoader();
                $.ajax({
                    url: '@Url.Action("Logout", "Auth")',
                    type: 'POST',
                    contentType: 'application/json',
                    success: function(resp) {
                        window.location.href = '@Url.Action("Index", "Auth")';
                    },
                    error: function() {
                        $('#loginError').text('Error de conexión. Intente nuevamente.');
                    }
                });
            });
        });
        
        let alertToast = (title, message, isError, options = {}) => {
           const color = options.color || (isError ? '#dc3545' : '#198754');
           const iconSVG = options.icon || `<svg aria-hidden="true" class="bd-placeholder-img rounded me-2" height="20" width="20" xmlns="http://www.w3.org/2000/svg"><rect width="100%" height="100%" fill="${color}"></rect></svg>`;

           return `
              <div class="toast show" role="alert" aria-live="assertive" aria-atomic="true">
                 <div class="toast-header">
                    ${iconSVG}
                    <strong class="me-auto">${title}</strong>
                    <small class="text-body-secondary"></small>
                    <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
                 </div>
                 <div class="toast-body">
                    ${message}
                 </div>
              </div>
           `;
        }
        
        let showLoader = () => {
            $('.modal2').addClass('modal2--show');
            $('.loader').addClass('loader--show');
        }
        let hideLoader = () => {
            $('.modal2').removeClass('modal2--show');
            $('.loader').removeClass('loader--show');
        }

        let alertError = (title, message) => {
           $('#toastContainer').append($(alertToast(title, message, true)));
        }
        let alertSuccess = (title, message) => {
           $('#toastContainer').append($(alertToast(title, message, false)));
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
