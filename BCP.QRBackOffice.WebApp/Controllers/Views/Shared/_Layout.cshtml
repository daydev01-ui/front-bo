                            <button id="btnLogOut" type="button" class="button-icon" tabindex="0" data-bs-toggle="popoverHeader" 
                            data-bs-trigger="hover" data-bs-placement="bottom" data-bs-content="Cerrar sesión">
                                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none"
                                     viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
